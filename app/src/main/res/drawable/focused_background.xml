<?xml version="1.0" encoding="utf-8"?>
<!--
    Focus indicator (C-5). state_focused="true"일 때 3dp stroke로 시인성 확보.
    stroke 색상은 테마 attr a11yFocusStroke로 분기 (light=red, HC=yellow).
    android:foreground로 적용 → ?selectableItemBackground와 충돌 없이 위에 그려짐 (API 23+).
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <stroke
                android:width="@dimen/a11y_focus_stroke"
                android:color="?attr/a11yFocusStroke" />
            <solid android:color="@android:color/transparent" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
