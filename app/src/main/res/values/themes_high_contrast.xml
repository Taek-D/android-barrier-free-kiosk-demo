<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        고대비 테마 (HC-02). 명도 대비 21:1 (#FFFFFF ↔ #000000), focus는 19.56:1 (#FFFF00 ↔ #000000).
        WCAG AA(4.5:1) 기준 대비 4.6배 여유. 키오스크 환경에서 시인성 우선.
    -->
    <style name="Theme.A11yDemo.HighContrast" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/a11y_hc_primary</item>
        <item name="colorPrimaryDark">@color/a11y_hc_background</item>
        <item name="colorAccent">@color/a11y_hc_primary</item>
        <item name="android:windowBackground">@color/a11y_hc_background</item>
        <item name="android:textColorPrimary">@color/a11y_hc_on_surface</item>
        <item name="android:textColorSecondary">@color/a11y_hc_on_surface</item>
        <item name="android:textColorHint">@color/a11y_hc_on_surface</item>
        <item name="android:statusBarColor" tools:targetApi="21">@color/a11y_hc_background</item>
        <item name="a11yBottomBarBg">@color/a11y_hc_bottom_bar_bg</item>
        <item name="a11yFocusStroke">@color/a11y_hc_primary</item>
    </style>
</resources>
